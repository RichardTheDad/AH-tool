# ── Backend environment variables ───────────────────────────────────────────

# PostgreSQL connection string (Supabase transaction pooler recommended for serverless,
# session pooler for long-running processes, direct for migrations)
AZEROTHFLIPLOCAL_DATABASE_URL=postgresql+psycopg2://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Supabase JWT secret (Settings → API → JWT Secret in your Supabase project dashboard)
AZEROTHFLIPLOCAL_SUPABASE_JWT_SECRET=

# Supabase project URL (e.g., https://your-project.supabase.co)
AZEROTHFLIPLOCAL_SUPABASE_URL=

# Fail fast on startup when auth-critical settings are missing
AZEROTHFLIPLOCAL_ENFORCE_AUTH_STARTUP_VALIDATION=true

# Restrict detailed health diagnostics endpoints (/health/scheduler and /health/metadata)
AZEROTHFLIPLOCAL_RESTRICT_HEALTH_DIAGNOSTICS=false
# Optional API key accepted via X-Health-Key header when diagnostics are restricted
AZEROTHFLIPLOCAL_HEALTH_DIAGNOSTICS_API_KEY=

# Blizzard API credentials (https://develop.battle.net/access)
AZEROTHFLIPLOCAL_BLIZZARD_CLIENT_ID=
AZEROTHFLIPLOCAL_BLIZZARD_CLIENT_SECRET=

# How often the background scheduler fetches fresh listing data (minutes, default 30)
AZEROTHFLIPLOCAL_SCHEDULER_REFRESH_INTERVAL_MINUTES=30

# Database pool tuning (for PostgreSQL deployments)
AZEROTHFLIPLOCAL_DB_POOL_SIZE=8
AZEROTHFLIPLOCAL_DB_MAX_OVERFLOW=8
AZEROTHFLIPLOCAL_DB_POOL_TIMEOUT_SECONDS=30
AZEROTHFLIPLOCAL_DB_POOL_RECYCLE_SECONDS=1800

# Comma-separated list of allowed CORS origins
# Example: https://your-app.vercel.app,https://azerothflip.com
AZEROTHFLIPLOCAL_CORS_ORIGINS=http://localhost:5173,https://azerothfliplocal.com,https://www.azerothfliplocal.com
