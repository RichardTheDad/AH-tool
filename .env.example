# ── Backend environment variables ───────────────────────────────────────────

# PostgreSQL connection string (Supabase transaction pooler recommended for serverless,
# session pooler for long-running processes, direct for migrations)
AZEROTHFLIPLOCAL_DATABASE_URL=postgresql+psycopg2://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Supabase JWT secret (Settings → API → JWT Secret in your Supabase project dashboard)
AZEROTHFLIPLOCAL_SUPABASE_JWT_SECRET=

# Blizzard API credentials (https://develop.battle.net/access)
AZEROTHFLIPLOCAL_BLIZZARD_CLIENT_ID=
AZEROTHFLIPLOCAL_BLIZZARD_CLIENT_SECRET=

# How often the background scheduler fetches fresh listing data (minutes, default 30)
AZEROTHFLIPLOCAL_SCHEDULER_REFRESH_INTERVAL_MINUTES=30

# Comma-separated list of allowed CORS origins
# Example: https://your-app.vercel.app,https://azerothflip.com
AZEROTHFLIPLOCAL_CORS_ORIGINS=http://localhost:5173
